# graphify codemap: commit the portable graph artifacts, ignore machine-specific
# markers (absolute paths), the regenerable cache, the absolute-path manifest, and
# the timestamped semantic-graph backups graphify writes on each re-cluster.
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_detect.json
graphify-out/cache/
graphify-out/manifest.json
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
